<button
  class="inline-flex items-center p-[3px] border border-[var(--line)] rounded-full bg-[var(--paper)] text-[var(--ink)] cursor-pointer relative transition-[border-color,background] duration-200 hover:border-[var(--brand)]"
  id="theme-toggle"
  aria-label="Cambiar tema"
>
  <span class="toggle-thumb"></span>
  <span id="wrap-sun"><i data-lucide="sun"></i></span>
  <span id="wrap-moon"><i data-lucide="moon"></i></span>
</button>
