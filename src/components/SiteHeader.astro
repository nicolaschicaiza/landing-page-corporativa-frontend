---
import BrandLogo from "./BrandLogo.astro";
import SiteNav from "./SiteNav.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";
import MobileMenuToggle from "./MobileMenuToggle.astro";
---

<header
  class="sticky top-0 z-40 bg-[var(--header-bg)] backdrop-blur-[10px] border-b border-[var(--header-border)] transition-[background,border-color] duration-300"
>
  <div class="wrapper flex justify-between items-center min-h-[74px]">
    <BrandLogo variant="header" href="/#inicio" />

    <SiteNav variant="header" id="main-nav" class="flex items-center gap-5" />

    <div class="flex items-center gap-2">
      <LanguageSwitcher />

      <ThemeToggle />

      <MobileMenuToggle />
    </div>
  </div>
</header>
