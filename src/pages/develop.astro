---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import TechCapsules from "../components/TechCapsules.astro";
import es from "../i18n/es.json";
import en from "../i18n/en.json";

const i18n = { es, en };

const coreFrameworks = [
  { icon: "⚡", name: "Next.js" },
  { icon: "⚛️", name: "React" },
  { icon: "🖖", name: "Vue.js" },
  { icon: "💚", name: "Nuxt" },
  { icon: "🅰️", name: "Angular" },
  { icon: "🔥", name: "Svelte" },
];

const fullStack = [
  { icon: "📙", name: "JavaScript" },
  { icon: "📘", name: "TypeScript" },
  { icon: "🟢", name: "Node.js" },
  { icon: "🚂", name: "Express" },
  { icon: "🧱", name: "NestJS" },
  { icon: "🐍", name: "Python" },
  { icon: "🎸", name: "Django" },
  { icon: "🚀", name: "Astro" },
  { icon: "🎨", name: "Tailwind CSS" },
  { icon: "⚡", name: "Vite" },
  { icon: "🗄️", name: "Supabase" },
  { icon: "☁️", name: "AWS" },
  { icon: "▲", name: "Vercel" },
  { icon: "🔗", name: "n8n" },
  { icon: "📱", name: "Meta Developer" },
  { icon: "🤖", name: "Relevance AI" },
  { icon: "🧠", name: "OpenAI" },
  { icon: "🐘", name: "PostgreSQL" },
  { icon: "🍃", name: "MongoDB" },
  { icon: "🔥", name: "Firebase" },
  { icon: "🐳", name: "Docker" },
  { icon: "📦", name: "Git" },
  { icon: "🔌", name: "REST APIs" },
  { icon: "◈", name: "GraphQL" },
  { icon: "🛒", name: "Shopify" },
  { icon: "📝", name: "WordPress" },
  { icon: "💳", name: "Stripe" },
];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>IntelliaWorks | Equipo de Desarrollo</title>
    <meta
      name="description"
      content="Equipo de freelancers expertos en desarrollo de soluciones digitales a medida."
    />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme");
        const savedThemeMode = localStorage.getItem("theme-mode");
        const isManualMode = savedThemeMode === "manual";
        const isValidSavedTheme = savedTheme === "dark" || savedTheme === "light";
        const prefersDark =
          window.matchMedia?.("(prefers-color-scheme: dark)")?.matches ?? false;
        const resolvedTheme = isManualMode && isValidSavedTheme
          ? savedTheme
          : prefersDark
            ? "dark"
            : "light";

        document.documentElement.setAttribute("data-theme", resolvedTheme);
      })();
    </script>
  </head>
  <body class="m-0">
    <div class="bg-orb orb-a" aria-hidden="true"></div>
    <div class="bg-orb orb-b" aria-hidden="true"></div>

    <SiteHeader />

    <main>
      <section
        id="inicio"
        class="flex items-center min-h-[calc(100svh-74px)] max-[980px]:min-h-0 py-10 max-[980px]:py-8 bg-[var(--tone-hero)] transition-[background] duration-300"
      >
        <div class="wrapper max-w-[1040px] flex flex-col items-center text-center">
          <div class="max-w-[760px] mx-auto">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold">
              Equipo especializado
            </p>
            <h1 class="m-0 text-[clamp(2.2rem,4vw,4rem)] leading-[1.04] text-[var(--ink)]">
              Freelancers Expertos<br />A Tu Servicio
            </h1>
            <p class="mt-4 mb-0 text-[1.03rem] text-[var(--muted)] max-w-[60ch]">
              Somos un equipo de desarrolladores independientes especializados en crear soluciones digitales a medida. Desde aplicaciones web hasta automatización de procesos, transformamos tus ideas en realidad con tecnología de vanguardia.
            </p>
          </div>

          <div class="mt-8 w-full">
            <TechCapsules items={coreFrameworks} containerClass="justify-center" />
          </div>
        </div>
      </section>

      <section
        id="servicios"
        class="py-20 max-[980px]:py-14 bg-[var(--tone-a)] transition-[background] duration-300"
      >
        <div class="wrapper flex flex-col items-center text-center">
          <div class="max-w-[800px] mx-auto">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold">
              Tecnología
            </p>
            <h2 class="m-0 text-[clamp(1.8rem,3.8vw,2.7rem)] leading-[1.1] text-[var(--ink)]">
              Nuestro Stack Tecnológico
            </h2>
            <p class="mt-3 mb-0 text-[var(--muted)] max-w-[62ch]">
              Dominamos las herramientas más modernas y demandadas para construir soluciones robustas y escalables.
            </p>
          </div>

          <div class="mt-7 w-full">
            <TechCapsules items={fullStack} containerClass="justify-center" />
          </div>
        </div>
      </section>

      <section
        id="contacto"
        class="py-20 max-[980px]:py-14 bg-[var(--tone-b)] transition-[background] duration-300"
      >
        <div class="wrapper flex flex-col items-center text-center">
          <div class="max-w-[780px] mx-auto">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold">
              Contacto
            </p>
            <h2 class="m-0 text-[clamp(1.8rem,3.8vw,2.7rem)] leading-[1.1] text-[var(--ink)]">
              Trabajemos Juntos
            </h2>
            <p class="mt-3 mb-0 text-[var(--muted)] max-w-[62ch]">
              ¿Tienes un proyecto en mente? Contáctanos y hablemos de cómo podemos ayudarte a alcanzar tus objetivos.
            </p>
          </div>

          <div class="mt-7 flex flex-wrap gap-3 justify-center">
            <a
              href="#"
              aria-disabled="true"
              class="inline-flex items-center justify-center rounded-xl px-[1.12rem] py-[0.78rem] text-[0.94rem] font-bold border border-[var(--ghost-border)] bg-[var(--paper)] text-[var(--ink)] opacity-80 cursor-not-allowed"
            >
              WhatsApp (próximamente)
            </a>
            <a
              href="/#contacto"
              class="btn-primary inline-flex items-center justify-center rounded-xl px-[1.12rem] py-[0.78rem] text-[0.94rem] font-bold border border-transparent hover:-translate-y-0.5 transition-[transform,box-shadow,background] duration-200"
            >
              Contacto
            </a>
          </div>
        </div>
      </section>
    </main>

    <SiteFooter />

    <script>
      // @ts-nocheck
      const menuToggle = document.querySelector("#menu-toggle");
      const nav = document.querySelector("#main-nav");
      const navLinks = document.querySelectorAll("#main-nav a");

      menuToggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("open");
        menuToggle.classList.toggle("open", isOpen);
      });

      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          nav?.classList.remove("open");
          menuToggle?.classList.remove("open");
        });
      });

      const themeToggle = document.getElementById("theme-toggle");
      const prefersDarkMedia = window.matchMedia?.("(prefers-color-scheme: dark)");

      function getThemeMode() {
        return localStorage.getItem("theme-mode") === "manual"
          ? "manual"
          : "system";
      }

      function getSavedTheme() {
        const savedTheme = localStorage.getItem("theme");
        return savedTheme === "dark" || savedTheme === "light"
          ? savedTheme
          : null;
      }

      function getSystemTheme() {
        return prefersDarkMedia?.matches ? "dark" : "light";
      }

      function applyTheme(newTheme, options = { persist: true }) {
        document.documentElement.setAttribute("data-theme", newTheme);
        if (options.persist) {
          localStorage.setItem("theme", newTheme);
          localStorage.setItem("theme-mode", "manual");
        }
      }

      function syncThemeWithSystemPreference() {
        if (getThemeMode() === "manual" && getSavedTheme()) return;
        applyTheme(getSystemTheme(), { persist: false });
      }

      syncThemeWithSystemPreference();

      const handleSystemThemeChange = () => syncThemeWithSystemPreference();

      if (prefersDarkMedia?.addEventListener) {
        prefersDarkMedia.addEventListener("change", handleSystemThemeChange);
      } else if (prefersDarkMedia?.addListener) {
        prefersDarkMedia.addListener(handleSystemThemeChange);
      }

      themeToggle?.addEventListener("click", async (e) => {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";
        const newTheme = isDark ? "light" : "dark";

        if (!document.startViewTransition) {
          applyTheme(newTheme);
          return;
        }

        const { clientX, clientY } = e;
        const maxRadius = Math.hypot(
          Math.max(clientX, window.innerWidth - clientX),
          Math.max(clientY, window.innerHeight - clientY),
        );

        document.documentElement.classList.add("theme-switching");

        try {
          const transition = document.startViewTransition(() =>
            applyTheme(newTheme),
          );

          await transition.ready;

          const anim = document.documentElement.animate(
            {
              clipPath: [
                `circle(0px at ${clientX}px ${clientY}px)`,
                `circle(${maxRadius}px at ${clientX}px ${clientY}px)`,
              ],
            },
            {
              duration: 800,
              easing: "cubic-bezier(0.4, 0, 0.2, 1)",
              pseudoElement: "::view-transition-new(root)",
            },
          );

          await anim.finished;
        } finally {
          document.documentElement.classList.remove("theme-switching");
        }
      });
    </script>

    <script define:vars={{ i18n }}>
      window.__i18n__ = i18n;

      function getVal(obj, path) {
        return path.split(".").reduce((acc, k) => acc?.[k], obj);
      }

      function applyTranslations(lang) {
        const t = window.__i18n__[lang] || window.__i18n__["es"];

        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const val = getVal(t, el.dataset.i18n);
          if (val !== undefined) el.textContent = val;
        });

        document.querySelectorAll("[data-i18n-html]").forEach((el) => {
          const val = getVal(t, el.dataset.i18nHtml);
          if (val !== undefined) el.innerHTML = val;
        });

        document.querySelectorAll("[data-i18n-aria]").forEach((el) => {
          const val = getVal(t, el.dataset.i18nAria);
          if (val !== undefined) el.setAttribute("aria-label", val);
        });

        document.documentElement.lang = lang;

        const langLabel = document.getElementById("lang-label");
        if (langLabel) langLabel.textContent = lang.toUpperCase();

        document.querySelectorAll("#lang-dropdown button").forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.lang === lang);
        });

        localStorage.setItem("lang", lang);
      }

      const savedLang = localStorage.getItem("lang") || "es";
      applyTranslations(savedLang);

      const langSwitcherEl = document.getElementById("lang-switcher");
      const langBtnEl = document.getElementById("lang-btn");

      langBtnEl?.addEventListener("click", (e) => {
        e.stopPropagation();
        langSwitcherEl?.classList.toggle("open");
      });

      document.querySelectorAll("#lang-dropdown button").forEach((btn) => {
        btn.addEventListener("click", () => {
          applyTranslations(btn.dataset.lang);
          langSwitcherEl?.classList.remove("open");
        });
      });

      document.addEventListener("click", (e) => {
        if (!langSwitcherEl?.contains(e.target)) {
          langSwitcherEl?.classList.remove("open");
        }
      });
    </script>

    <script>
      import { createIcons, ChevronDown, Sun, Moon } from "lucide";
      createIcons({ icons: { ChevronDown, Sun, Moon } });
    </script>
  </body>
</html>
