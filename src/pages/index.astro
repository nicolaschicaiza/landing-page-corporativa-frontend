                          class="icon-badge icon-badge-cloud"
                          aria-hidden="true"
                          ><svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                              d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9z"
                            ></path></svg
                          ></span
                        >
                        <span
                          class="service-option-label"
                          data-i18n="contact.form.service4">Cloud y DevOps</span
                        >
                        <span class="service-check ml-auto" aria-hidden="true"
                          ><svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polyline points="20 6 9 17 4 12"></polyline></svg
                          ></span
                        >
                      </li>
                      <li
                        role="option"
                        aria-selected="false"
                        data-value="qa"
                        class="service-option flex items-center gap-[0.75rem] px-[0.75rem] py-[0.55rem] cursor-pointer rounded-[8px] mx-[0.25rem] transition-[background,color,box-shadow] duration-150"
                      >
                        <span
                          class="icon-badge icon-badge-qa"
                          aria-hidden="true"
                          ><svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="15"
                            height="15"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                              d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path><polyline points="9 12 11 14 15 10"
                            ></polyline></svg
                          ></span
                        >
                        <span
                          class="service-option-label"
                          data-i18n="contact.form.service5">QA y calidad</span
                        >
                        <span class="service-check ml-auto" aria-hidden="true"
                          ><svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polyline points="20 6 9 17 4 12"></polyline></svg
                          ></span
                        >
                      </li>
                    </ul>
                  </div>
                </div>
                <label class="grid gap-[0.35rem]">
                  <span
                    class="text-[0.75rem] font-bold uppercase tracking-[0.07em] text-[var(--muted)]"
                    data-i18n="contact.form.message"
                    >Cuéntanos sobre tu proyecto</span
                  >
                  <textarea
                    name="message"
                    rows="4"
                    required
                    class="w-full border border-[var(--input-border)] rounded-[10px] bg-[var(--input-bg)] text-[var(--ink)] px-[0.72rem] py-[0.72rem] font-[inherit] text-[1rem] min-h-[120px] resize-y transition-[border-color,background,color] duration-200"
                    data-i18n-placeholder="contact.form.messagePlaceholder"
                  ></textarea>
                </label>
                <label class="hidden" aria-hidden="true">
                  <span>Empresa</span>
                  <input
                    name="company"
                    type="text"
                    autocomplete="off"
                    tabindex="-1"
                  />
                </label>
                <input
                  type="hidden"
                  name="captchaToken"
                  id="captcha-token"
                  value=""
                />
                <input
                  type="hidden"
                  name="submittedAt"
                  id="submittedAt"
                  value=""
                />
                {
                  recaptchaSiteKey && (
                    <div class="grid gap-[0.45rem]">
                      <div
                        id="recaptcha-widget"
                        class="min-h-[78px] flex justify-center"
                      />
                    </div>
                  )
                }
                <button
                  type="submit"
                  id="submit-btn"
                  disabled
                  class="btn-primary w-full inline-flex items-center justify-center rounded-xl px-[1.12rem] py-[0.78rem] text-[0.94rem] font-bold border border-transparent mt-1 hover:-translate-y-0.5 transition-[transform,box-shadow,background,color] duration-200 cursor-pointer disabled:cursor-not-allowed disabled:pointer-events-none"
                  data-i18n="contact.form.submit">Enviar mensaje</button
                >
                <p class="m-0 min-h-[1.2rem] text-[var(--muted)]" id="status">
                </p>
              </form>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Footer ──────────────────────────────────────── -->
      <footer class="w-[min(1120px,90vw)] mx-auto pt-0 pb-11">
        <div
          class="flex items-center justify-between gap-6 border-t border-[var(--footer-border)] pt-6 flex-wrap transition-[border-color] duration-300"
        >
          <a
            href="#inicio"
            class="inline-flex opacity-85 hover:opacity-100 transition-opacity duration-200"
          >
            <img
              src={logo.src}
              alt="IntelliaWorks"
              class="footer-logo logo-dark h-8 w-auto block"
              width="140"
              height="32"
            />
            <img
              src={logoLight.src}
              alt="IntelliaWorks"
              class="footer-logo logo-light h-8 w-auto"
              width="140"
              height="32"
            />
          </a>
          <nav class="flex items-center gap-5 flex-wrap">
            <NavLinks variant="footer" />
          </nav>
        </div>
        <p
          class="mt-3 text-[var(--muted)] text-[0.875rem] text-center w-full m-0"
        >
          &copy; {new Date().getFullYear()} IntelliaWorks. <span
            data-i18n="footer.rights">Todos los derechos reservados.</span>
        </p>
      </footer>
    </main>

    <script>
      // @ts-nocheck
      const recaptchaSiteKey = document.body.dataset.recaptchaSiteKey ?? "";

      // --- Custom smooth scroll: ease-in-out cubic (slow → fast → slow) ---
      function easeInOut(t) {
        return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
      }

      function smoothScrollTo(targetY) {
        const startY = window.scrollY;
        const distance = targetY - startY;
        if (Math.abs(distance) < 2) return;
        // Duration proportional to distance, clamped 380ms–750ms
        const duration = Math.min(
          750,
          Math.max(380, Math.abs(distance) * 0.22),
        );
        const startTime = performance.now();

        function step(now) {
          const elapsed = now - startTime;
          const progress = Math.min(elapsed / duration, 1);
          window.scrollTo(0, startY + distance * easeInOut(progress));
          if (progress < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      // Intercept all internal anchor clicks
      document.addEventListener("click", (e) => {
        const source = e.target;
        if (!(source instanceof Element)) return;
        const anchor = source.closest("a[href^='#']");
        if (!anchor) return;
        const href = anchor.getAttribute("href");
        if (!href) return;
        const id = href.slice(1);
        const target = id ? document.getElementById(id) : null;
        if (!target) return;
        e.preventDefault();
        const headerOffset = 74;
        const targetY =
          target.getBoundingClientRect().top + window.scrollY - headerOffset;
        smoothScrollTo(targetY);
        // Update hash without jumping
        history.pushState(null, "", `#${id}`);
      });
      // --- fin custom scroll ---

      // --- Scroll down / scroll top ---
      const scrollTopBtn = document.querySelector("#scroll-top");
      const scrollDownBtn = document.querySelector("#scroll-down");

      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      if (!window.location.hash) {
        window.scrollTo({ top: 0, left: 0, behavior: "auto" });
      }

      scrollTopBtn?.addEventListener("click", () => {
        smoothScrollTo(0);
      });

      const updateScrollButtons = () => {
        const showDown = window.scrollY < window.innerHeight * 0.45;
        scrollDownBtn?.classList.toggle("visible", showDown);
        scrollTopBtn?.classList.toggle("visible", !showDown);
      };

      const updateBackgroundShift = () => {
        const y = window.scrollY;
        const shift = Math.min(y * 0.16, 220);

        document.documentElement.style.setProperty("--bg-shift", `${shift}px`);
        document.documentElement.style.setProperty(
          "--orb-a-y",
          `${Math.min(y * 0.55, 900)}px`,
        );
        document.documentElement.style.setProperty(
          "--orb-b-y",
          `${Math.min(y * 0.82, 1300)}px`,
        );
        document.documentElement.style.setProperty(
          "--orb-a-x",
          `${Math.sin(y * 0.0032) * 74}px`,
        );
        document.documentElement.style.setProperty(
          "--orb-b-x",
          `${Math.sin(y * 0.0027 + 1.1) * -92}px`,
        );
      };

      updateScrollButtons();
      updateBackgroundShift();

      let scrollTicking = false;
      const onScroll = () => {
        if (scrollTicking) return;
        scrollTicking = true;
        requestAnimationFrame(() => {
          updateScrollButtons();
          updateBackgroundShift();
          scrollTicking = false;
        });
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("pageshow", (event) => {
        if (event.persisted && !window.location.hash) {
          window.scrollTo({ top: 0, left: 0, behavior: "auto" });
        }
        updateScrollButtons();
        updateBackgroundShift();
      });
      // --- fin scroll ---

      // --- Active nav link on scroll ---
      const navLinkEls = document.querySelectorAll("#main-nav a.nav-link");
      const sectionIds = Array.from(navLinkEls)
        .map((a) => a.dataset.section)
        .filter(Boolean);
      // Also observe #inicio so we can clear the active state when there
      const allObservedIds = ["inicio", ...sectionIds];
      const allObservedEls = allObservedIds
        .map((id) => document.getElementById(id))
        .filter(Boolean);

      let activeSection = "";

      const setActive = (id) => {
        if (id === activeSection) return;
        activeSection = id;
        // If #inicio is active, clear all; otherwise highlight the matching link
        navLinkEls.forEach((a) => {
          a.classList.toggle(
            "nav-active",
            id !== "inicio" && a.dataset.section === id,
          );
        });
      };

      const sectionObserver = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio);
          if (visible.length) setActive(visible[0].target.id);
        },
        { threshold: [0.25, 0.5], rootMargin: "-10% 0px -10% 0px" },
      );

      allObservedEls.forEach((s) => sectionObserver.observe(s));
      // --- fin active nav ---

      const menuToggle = document.querySelector("#menu-toggle");
      const nav = document.querySelector("#main-nav");
      const navLinks = document.querySelectorAll("#main-nav a");

      menuToggle?.addEventListener("click", () => {
        const isOpen = nav?.classList.toggle("open");
        menuToggle.classList.toggle("open", isOpen);
      });

      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          nav?.classList.remove("open");
          menuToggle?.classList.remove("open");
        });
      });

      const revealNodes = document.querySelectorAll(".reveal");
      const revealItemGroups = [
        ".hero-copy > *",
        ".hero-showcase > *",
        ".section-heading > *",
        ".service-card",
        ".timeline article",
        ".results-grid article",
        ".faq-item",
        ".contact-trust > *",
        "#lead-form > *",
      ];

      revealNodes.forEach((section) => {
        const stagedItems = revealItemGroups.flatMap((selector) =>
          Array.from(section.querySelectorAll(selector)),
        );
        const uniqueItems = Array.from(new Set(stagedItems));

        uniqueItems.forEach((item, index) => {
          item.classList.add("reveal-item");
          item.style.setProperty(
            "--reveal-delay",
            `${Math.min(index * 120, 1400)}ms`,
          );
        });
      });

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.22, rootMargin: "0px 0px -12% 0px" },
      );

      revealNodes.forEach((node) => observer.observe(node));

      // ── FAQ Accordion ────────────────────────────────────────
      const faqAccordion = document.getElementById("faq-accordion");
      faqAccordion?.querySelectorAll(".faq-item").forEach((item) => {
        const btn = item.querySelector(".faq-btn");
        btn?.addEventListener("click", () => {
          const isOpen = item.classList.contains("open");
          // Close all
          faqAccordion.querySelectorAll(".faq-item").forEach((el) => {
            el.classList.remove("open");
            el.querySelector(".faq-btn")?.setAttribute(
              "aria-expanded",
              "false",
            );
          });
          // Open clicked if it was closed
          if (!isOpen) {
            item.classList.add("open");
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });

      const form = document.querySelector("#lead-form");
      const status = document.querySelector("#status");
      const submittedAtInput = document.querySelector("#submittedAt");
      const captchaTokenInput = document.querySelector("#captcha-token");
      const recaptchaWidgetEl = document.querySelector("#recaptcha-widget");
      const submitBtn = document.querySelector("#submit-btn");

      const checkFormValidity = () => {
        const nameVal = form?.querySelector('[name="name"]')?.value?.trim() ?? "";
        const emailVal = form?.querySelector('[name="email"]')?.value?.trim() ?? "";
        const serviceVal = document.getElementById("service-value")?.value ?? "";
        const messageVal = form?.querySelector('[name="message"]')?.value?.trim() ?? "";
        const captchaOk = !recaptchaSiteKey || !!(captchaTokenInput?.value);
        const allFilled = !!(nameVal && emailVal && serviceVal && messageVal && captchaOk);
        if (submitBtn) submitBtn.disabled = !allFilled;
      };

      form?.querySelector('[name="name"]')?.addEventListener("input", checkFormValidity);
      form?.querySelector('[name="email"]')?.addEventListener("input", checkFormValidity);
      form?.querySelector('[name="message"]')?.addEventListener("input", checkFormValidity);

      let recaptchaWidgetId = null;
      let recaptchaInitAttempts = 0;

      const resetRecaptcha = () => {
        captchaTokenInput && (captchaTokenInput.value = "");
        if (recaptchaWidgetId !== null && window.grecaptcha?.reset) {
          window.grecaptcha.reset(recaptchaWidgetId);
        }
      };

      const renderRecaptcha = (theme) => {
        if (!recaptchaSiteKey || !recaptchaWidgetEl || !window.grecaptcha?.render) return;
        if (recaptchaWidgetEl) recaptchaWidgetEl.innerHTML = "";
        recaptchaWidgetId = null;
        if (captchaTokenInput) captchaTokenInput.value = "";
        recaptchaWidgetId = window.grecaptcha.render(recaptchaWidgetEl, {
          sitekey: recaptchaSiteKey,
          theme,
          callback: (token) => {
            if (captchaTokenInput) captchaTokenInput.value = token;
            checkFormValidity();
          },
          "expired-callback": () => {
            if (captchaTokenInput) captchaTokenInput.value = "";
            checkFormValidity();
          },
          "error-callback": () => {
            if (captchaTokenInput) captchaTokenInput.value = "";
            checkFormValidity();
          },
        });
      };

      const initRecaptcha = () => {
        if (
          !recaptchaSiteKey ||
          !recaptchaWidgetEl ||
          recaptchaWidgetId !== null
        )
          return;

        const grecaptcha = window.grecaptcha;
        if (!grecaptcha?.render) {
          if (recaptchaInitAttempts < 30) {
            recaptchaInitAttempts += 1;
            window.setTimeout(initRecaptcha, 300);
          }
          return;
        }

        const theme =
          document.documentElement.getAttribute("data-theme") === "dark"
            ? "dark"
            : "light";
        renderRecaptcha(theme);
      };

      initRecaptcha();

      // Re-render reCAPTCHA once the View Transition animation fully ends.
      // We watch for the removal of the 'theme-switching' class (added at
      // transition start, removed in anim.finish) so there is no fixed timeout
      // and the widget is never wiped while the snapshot is active.
      // CSS already hides the widget during the transition (html.theme-switching #recaptcha-widget).
      if (recaptchaSiteKey && recaptchaWidgetEl) {
        new MutationObserver((mutations) => {
          for (const m of mutations) {
            if (
              m.attributeName === "class" &&
              !document.documentElement.classList.contains("theme-switching")
            ) {
              const theme =
                document.documentElement.getAttribute("data-theme") === "dark"
                  ? "dark"
                  : "light";
              renderRecaptcha(theme);
              checkFormValidity();
              break;
            }
          }
        }).observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      form?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const t = (key) => {
          const lang = window.__currentLang__ || "es";
          return (
            key.split(".").reduce((o, k) => o?.[k], window.__i18n__?.[lang]) ??
            key
          );
        };
        if (status) status.textContent = t("contact.form.sending");

        if (submittedAtInput) {
          submittedAtInput.value = Date.now().toString();
        }

        if (recaptchaSiteKey && !captchaTokenInput?.value) {
          if (status) status.textContent = t("contact.form.captchaRequired");
          return;
        }

        const data = new FormData(form);
        const payload = Object.fromEntries(data.entries());

        try {
          const response = await fetch("/.netlify/functions/contact", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          const result = await response.json();
          if (!response.ok || !result.ok) {
            throw new Error(
              result.message || "No se pudo enviar el formulario",
            );
          }

          form.reset();
          resetRecaptcha();
          checkFormValidity();
          if (status) status.textContent = t("contact.form.success");
        } catch (error) {
          if (recaptchaSiteKey) resetRecaptcha();
          if (status)
            status.textContent =
              error instanceof Error ? error.message : t("contact.form.error");
        }
      });

      // --- Custom service dropdown ---
      (function () {
        const dropdown = document.getElementById("service-dropdown");
        const btn = document.getElementById("service-btn");
        const listbox = document.getElementById("service-listbox");
        const display = document.getElementById("service-display");
        const hidden = document.getElementById("service-value");
        const options = listbox?.querySelectorAll(
          "li[data-value]:not([data-value=''])",
        );

        function openDropdown() {
          dropdown?.classList.add("open");
          btn?.setAttribute("aria-expanded", "true");
        }
        function closeDropdown() {
          dropdown?.classList.remove("open");
          btn?.setAttribute("aria-expanded", "false");
        }
        function selectOption(li) {
          const value = li.dataset.value ?? "";
          if (!value) return;
          hidden.value = value;

          // Update display text & colour
          const labelText =
            li.querySelector(".service-option-label")?.textContent ?? "";
          display.textContent = labelText;
          display.classList.remove("text-[var(--muted)]");
          display.classList.add("text-[var(--ink)]");

          // Update aria-selected
          options?.forEach((o) => o.setAttribute("aria-selected", "false"));
          li.setAttribute("aria-selected", "true");

          closeDropdown();
          checkFormValidity();
        }
        function resetDropdown() {
          hidden.value = "";
          const placeholder = listbox?.querySelector("li[data-value='']");
          display.textContent = placeholder?.textContent?.trim() ?? "";
          display.classList.add("text-[var(--muted)]");
          display.classList.remove("text-[var(--ink)]");
          options?.forEach((o) => o.setAttribute("aria-selected", "false"));
        }

        // Expose sync for i18n lang change
        window.__syncServiceDisplay__ = function () {
          const value = hidden?.value;
          if (!value) {
            const placeholder = listbox?.querySelector("li[data-value='']");
            if (placeholder && display)
              display.textContent = placeholder.textContent?.trim() ?? "";
          } else {
            const selected = listbox?.querySelector(
              `li[data-value="${value}"]`,
            );
            if (selected && display)
              display.textContent =
                selected.querySelector(".service-option-label")?.textContent ??
                "";
          }
        };

        btn?.addEventListener("click", (e) => {
          e.stopPropagation();
          dropdown?.classList.contains("open")
            ? closeDropdown()
            : openDropdown();
        });

        options?.forEach((li) => {
          li.addEventListener("click", () => selectOption(li));
        });

        document.addEventListener("click", (e) => {
          if (!(e.target instanceof Node)) return;
          if (!dropdown?.contains(e.target)) closeDropdown();
        });

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && dropdown?.classList.contains("open"))
            closeDropdown();
        });

        form?.addEventListener("reset", () => setTimeout(resetDropdown, 0));
      })();

      // --- Theme toggle (epic circular reveal) ---
      const themeToggle = document.getElementById("theme-toggle");

      function applyTheme(newTheme) {
        document.documentElement.setAttribute("data-theme", newTheme);
        localStorage.setItem("theme", newTheme);
      }

      themeToggle?.addEventListener("click", async (e) => {
        const isDark =
          document.documentElement.getAttribute("data-theme") === "dark";
        const newTheme = isDark ? "light" : "dark";

        // Fallback for browsers without View Transitions
        if (!document.startViewTransition) {
          applyTheme(newTheme);
          return;
        }

        const { clientX, clientY } = e;
        const maxRadius = Math.hypot(
          Math.max(clientX, window.innerWidth - clientX),
          Math.max(clientY, window.innerHeight - clientY),
        );

        // Suppress competing element transitions during the view transition
        document.documentElement.classList.add("theme-switching");

        const transition = document.startViewTransition(() =>
          applyTheme(newTheme),
        );

        await transition.ready;

        const anim = document.documentElement.animate(
          {
            clipPath: [
              `circle(0px at ${clientX}px ${clientY}px)`,
              `circle(${maxRadius}px at ${clientX}px ${clientY}px)`,
            ],
          },
          {
            duration: 800,
            easing: "cubic-bezier(0.4, 0, 0.2, 1)",
            pseudoElement: "::view-transition-new(root)",
          },
        );

        anim.addEventListener("finish", () => {
          document.documentElement.classList.remove("theme-switching");
        });
      });
    </script>

    <script define:vars={{ i18n }}>
      // ── i18n engine ──────────────────────────────────────────
      window.__i18n__ = i18n;

      function getVal(obj, path) {
        return path.split(".").reduce((acc, k) => acc?.[k], obj);
      }

      function applyTranslations(lang) {
        const t = window.__i18n__[lang] || window.__i18n__["es"];

        document.querySelectorAll("[data-i18n]").forEach((el) => {
          const val = getVal(t, el.dataset.i18n);
          if (val !== undefined) el.textContent = val;
        });

        document.querySelectorAll("[data-i18n-html]").forEach((el) => {
          const val = getVal(t, el.dataset.i18nHtml);
          if (val !== undefined) el.innerHTML = val;
        });

        document.querySelectorAll("[data-i18n-aria]").forEach((el) => {
          const val = getVal(t, el.dataset.i18nAria);
          if (val !== undefined) el.setAttribute("aria-label", val);
        });

        document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
          const val = getVal(t, el.dataset.i18nPlaceholder);
          if (val !== undefined) el.setAttribute("placeholder", val);
        });

        document.documentElement.lang = lang;

        const langLabel = document.getElementById("lang-label");
        if (langLabel) langLabel.textContent = lang.toUpperCase();

        document.querySelectorAll("#lang-dropdown button").forEach((btn) => {
          btn.classList.toggle("active", btn.dataset.lang === lang);
        });

        localStorage.setItem("lang", lang);
        window.__currentLang__ = lang;

        // Sync custom service dropdown display label after translations update
        if (typeof window.__syncServiceDisplay__ === "function") {
          window.__syncServiceDisplay__();
        }
      }

      // Apply saved language on load
      const savedLang = localStorage.getItem("lang") || "es";
      applyTranslations(savedLang);

      // Language switcher UI
      const langSwitcherEl = document.getElementById("lang-switcher");
      const langBtnEl = document.getElementById("lang-btn");

      langBtnEl?.addEventListener("click", (e) => {
        e.stopPropagation();
        langSwitcherEl?.classList.toggle("open");
      });

      document.querySelectorAll("#lang-dropdown button").forEach((btn) => {
        btn.addEventListener("click", () => {
          applyTranslations(btn.dataset.lang);
          langSwitcherEl?.classList.remove("open");
        });
      });

      document.addEventListener("click", (e) => {
        if (!langSwitcherEl?.contains(e.target)) {
          langSwitcherEl?.classList.remove("open");
        }
      });
    </script>

    <script>
      import { createIcons, ChevronUp, ChevronDown, Sun, Moon } from "lucide";
      createIcons({ icons: { ChevronUp, ChevronDown, Sun, Moon } });
    </script>
  </body>
</html>
