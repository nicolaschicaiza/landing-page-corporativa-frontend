---
import "../styles/global.css";
import logo from "../images/logo.png";
import logoLight from "../images/logo_light.png";
import heroIllustration from "../images/illustrations/hero-services-storyset.svg";
import faqIllustration from "../images/faq.svg";
import es from "../i18n/es.json";
import en from "../i18n/en.json";
const i18n = { es, en };
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>IntelliaWorks | Servicios de tecnología freelance</title>
    <meta
      name="description"
      content="Desarrollo, gestión de proyectos, marketing, cloud y QA para equipos que buscan crecer con tecnología."
    />
    <!-- Prevent theme flash (FOUC) -->
    <script is:inline>
      (function () {
        const t = localStorage.getItem("theme");
        if (t === "dark") document.documentElement.setAttribute("data-theme", "dark");
      })();
    </script>
  </head>
  <body class="m-0">

    <!-- Background orbs -->
    <div class="fixed -z-[2] rounded-full blur-[56px] opacity-45 pointer-events-none w-[260px] h-[260px] bg-[var(--orb-a)] -left-[70px] top-[30vh] transition-[background] duration-[400ms]"></div>
    <div class="fixed -z-[2] rounded-full blur-[56px] opacity-45 pointer-events-none w-[280px] h-[280px] bg-[var(--orb-b)] -right-[80px] top-[18vh] transition-[background] duration-[400ms]"></div>

    <!-- ── Header ─────────────────────────────────────────── -->
    <header class="sticky top-0 z-40 bg-[var(--header-bg)] backdrop-blur-[10px] border-b border-[var(--header-border)] transition-[background,border-color] duration-300">
      <div class="wrapper flex justify-between items-center min-h-[74px]">

        <a class="inline-flex items-center" href="#inicio">
          <img src={logo.src}      alt="IntelliaWorks" class="logo-dark  h-9 w-auto block" width="160" height="36" />
          <img src={logoLight.src} alt="IntelliaWorks" class="logo-light h-9 w-auto"       width="160" height="36" />
        </a>

        <nav id="main-nav" class="flex items-center gap-5">
          <a href="#servicios"  class="nav-link text-[var(--muted)] text-[0.95rem] hover:text-[var(--ink)] transition-colors duration-200" data-section="servicios"  data-i18n="nav.services">Servicios</a>
          <a href="#proceso"    class="nav-link text-[var(--muted)] text-[0.95rem] hover:text-[var(--ink)] transition-colors duration-200" data-section="proceso"    data-i18n="nav.process">Proceso</a>
          <a href="#resultados" class="nav-link text-[var(--muted)] text-[0.95rem] hover:text-[var(--ink)] transition-colors duration-200" data-section="resultados" data-i18n="nav.results">Resultados</a>
          <a href="#faq"        class="nav-link text-[var(--muted)] text-[0.95rem] hover:text-[var(--ink)] transition-colors duration-200" data-section="faq"        data-i18n="nav.faq">FAQ</a>
          <a href="#contacto"   class="nav-link text-[var(--muted)] text-[0.95rem] hover:text-[var(--ink)] transition-colors duration-200" data-section="contacto" data-i18n="nav.cta">Hablemos</a>
        </nav>

        <div class="flex items-center gap-2">

          <!-- Language switcher -->
          <div class="relative" id="lang-switcher">
            <button class="inline-flex items-center gap-[0.28rem] border border-[var(--line)] rounded-lg bg-[var(--paper)] text-[var(--ink)] text-[0.8rem] font-semibold px-[0.6rem] py-[0.38rem] cursor-pointer transition-[border-color,background,color] duration-200 hover:border-[var(--brand)]" id="lang-btn" aria-label="Cambiar idioma">
              <span id="lang-label">ES</span>
              <i data-lucide="chevron-down" class="lang-chevron transition-transform duration-[220ms]" style="width:13px;height:13px"></i>
            </button>
            <div class="absolute top-[calc(100%+6px)] right-0 min-w-[130px] bg-[var(--paper)] border border-[var(--line)] rounded-xl shadow-[0_8px_24px_rgba(0,0,0,0.1)] overflow-hidden z-[100]" id="lang-dropdown">
              <button class="flex items-center gap-2 w-full px-[0.9rem] py-[0.55rem] text-left border-none bg-transparent text-[var(--muted)] text-[0.88rem] cursor-pointer hover:bg-[var(--bg-soft)] hover:text-[var(--ink)] transition-[background,color] duration-150" data-lang="es">🇪🇸 Español</button>
              <button class="flex items-center gap-2 w-full px-[0.9rem] py-[0.55rem] text-left border-none bg-transparent text-[var(--muted)] text-[0.88rem] cursor-pointer hover:bg-[var(--bg-soft)] hover:text-[var(--ink)] transition-[background,color] duration-150" data-lang="en">🇬🇧 English</button>
            </div>
          </div>

          <!-- Theme toggle -->
          <button class="inline-flex items-center p-[3px] border border-[var(--line)] rounded-full bg-[var(--paper)] text-[var(--ink)] cursor-pointer relative transition-[border-color,background] duration-200 hover:border-[var(--brand)]" id="theme-toggle" aria-label="Cambiar tema">
            <span class="toggle-thumb"></span>
            <span id="wrap-sun"><i data-lucide="sun"></i></span>
            <span id="wrap-moon"><i data-lucide="moon"></i></span>
          </button>

          <!-- Mobile menu button -->
          <button id="menu-toggle" class="menu-toggle hidden border border-[var(--line)] rounded-[10px] w-[42px] h-[42px] items-center justify-center flex-col bg-[var(--paper)] relative" type="button" aria-label="Abrir menú" data-i18n-aria="nav.menuLabel">
            <span></span>
            <span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- Scroll top FAB -->
    <button id="scroll-top" class="scroll-fab fixed bottom-8 right-8 z-[200] flex items-center justify-center w-[46px] h-[46px] rounded-full border-none bg-[var(--brand)] text-white cursor-pointer shadow-[0_4px_16px_rgba(0,0,0,0.18)] opacity-0 pointer-events-none translate-y-3 transition-[opacity,transform] duration-300 hover:bg-[var(--brand-strong)]" aria-label="Volver al inicio">
      <i data-lucide="chevron-up" class="w-5 h-5 block"></i>
    </button>

    <main>

      <!-- ── Hero ────────────────────────────────────────── -->
      <section id="inicio" class="relative flex items-center min-h-[calc(100svh-74px)] max-[980px]:min-h-0 py-8 max-[980px]:pt-6 max-[980px]:pb-6 bg-[var(--tone-hero)] transition-[background] duration-[400ms] scroll-mt-[74px] reveal">
        <div class="wrapper grid grid-cols-[minmax(350px,1fr)_minmax(320px,460px)] max-[980px]:grid-cols-1 items-center justify-center gap-[clamp(1rem,2.2vw,2.1rem)] max-w-[1060px] mx-auto py-4">

          <div class="hero-copy max-w-[580px]">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold" data-i18n="hero.eyebrow">Consultoría y ejecución digital</p>
            <h1 class="m-0 text-[clamp(2.35rem,4vw,4.1rem)] leading-[1.02] max-w-[11ch] text-balance text-[var(--ink)]" data-i18n="hero.headline">Construimos experiencias digitales que venden y escalan.</h1>
            <p class="mt-4 max-w-[52ch] text-[1.03rem] text-[var(--muted)] m-0" data-i18n="hero.lead">
              Combinamos desarrollo, marketing, cloud y QA para ayudarte a lanzar más rápido, convertir mejor y tomar decisiones con datos.
            </p>
            <div class="mt-6 flex gap-3 flex-wrap hero-actions">
              <a href="#contacto" class="btn-primary inline-flex items-center justify-center rounded-xl px-[1.12rem] py-[0.78rem] text-[0.94rem] font-bold border border-transparent hover:-translate-y-0.5 transition-[transform,box-shadow,background] duration-200 cursor-pointer" data-i18n="hero.cta">Solicitar propuesta</a>
              <a href="#servicios" class="inline-flex items-center justify-center rounded-xl px-[1.12rem] py-[0.78rem] text-[0.94rem] font-bold border border-[var(--ghost-border)] bg-[var(--paper)] text-[var(--ink)] hover:-translate-y-0.5 transition-[transform,box-shadow] duration-200" data-i18n="nav.services">Ver servicios</a>
            </div>
            <div class="mt-4 flex flex-wrap gap-2 hero-points">
              <span class="rounded-full border border-[var(--point-border)] bg-[var(--point-bg)] text-[var(--point-color)] px-[0.7rem] py-[0.35rem] text-[0.8rem] transition-[border-color,background] duration-300" data-i18n="hero.point1">Discovery estratégico</span>
              <span class="rounded-full border border-[var(--point-border)] bg-[var(--point-bg)] text-[var(--point-color)] px-[0.7rem] py-[0.35rem] text-[0.8rem] transition-[border-color,background] duration-300" data-i18n="hero.point2">Ejecución ágil</span>
              <span class="rounded-full border border-[var(--point-border)] bg-[var(--point-bg)] text-[var(--point-color)] px-[0.7rem] py-[0.35rem] text-[0.8rem] transition-[border-color,background] duration-300" data-i18n="hero.point3">Calidad desde el inicio</span>
            </div>
          </div>

          <aside class="hero-showcase relative grid gap-[0.72rem] content-start">
            <figure class="m-0 border border-[var(--illustration-border)] rounded-[22px] bg-[var(--illustration-bg)] shadow-[var(--shadow)] p-[0.7rem] transition-[border-color,background] duration-300" style="animation:heroIllustrationFloat 6s ease-in-out infinite">
              <img src={heroIllustration.src} alt="Ilustración de equipo planificando soluciones digitales" class="block w-full h-auto" loading="eager" decoding="async" />
            </figure>
            <p class="m-0 px-[0.3rem] text-center text-[var(--muted)] text-[0.9rem] leading-[1.4]" data-i18n="hero.caption">Estrategia y ejecución para acelerar resultados digitales.</p>
            <p class="mt-[-0.15rem] m-0 text-center text-[0.75rem] text-[#6f7f92]" data-i18n-html="hero.creditHtml">
              Ilustración por <a href="https://storyset.com/technology" target="_blank" rel="noopener noreferrer" class="underline">Storyset</a>
            </p>
          </aside>
        </div>

        <div class="absolute left-1/2 bottom-5 -translate-x-1/2 z-[5]">
          <a href="#servicios" id="scroll-down" class="scroll-down-btn flex items-center justify-center w-[52px] h-[52px] border-none bg-transparent text-[var(--brand-strong)] opacity-0 pointer-events-none -translate-y-2 transition-[opacity,transform,color] duration-300" aria-label="Deslizar hacia servicios">
            <i data-lucide="chevron-down" class="w-8 h-8 block"></i>
          </a>
        </div>
      </section>

      <!-- ── Servicios ───────────────────────────────────── -->
      <section id="servicios" class="flex items-center min-h-[100svh] max-[980px]:min-h-0 py-20 max-[980px]:py-[4.1rem] bg-[var(--tone-a)] transition-[background] duration-[400ms] scroll-mt-[74px] reveal">
        <div class="wrapper py-4">
          <div class="section-heading max-w-[760px]">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold" data-i18n="services.eyebrow">Servicios</p>
            <h2 class="m-0 text-[clamp(1.7rem,3.8vw,2.65rem)] leading-[1.09] text-[var(--ink)]" data-i18n="services.headline">Soluciones modulares para cada etapa de tu crecimiento digital</h2>
            <p class="mt-[0.7rem] mb-0 text-[var(--muted)] max-w-[56ch]" data-i18n="services.lead">
              Diseñamos estrategias y ejecutamos con foco en resultados de negocio, no solo entregables técnicos.
            </p>
          </div>
          <div class="mt-5 grid gap-[0.9rem] grid-cols-12 max-[760px]:grid-cols-1">
            <article class="service-card col-span-4 max-[980px]:col-span-6 max-[760px]:col-span-12 border border-[var(--card-border)] rounded-[18px] p-4 bg-[var(--paper)] shadow-[0_10px_24px_rgba(25,35,46,0.07)] hover:-translate-y-[5px] hover:shadow-[0_18px_34px_rgba(25,35,46,0.14)] transition-[transform,box-shadow,border-color,background] duration-[220ms]">
              <p class="m-0 mb-2 inline-flex text-[0.72rem] uppercase tracking-[0.12em] text-[var(--brand)] border border-[var(--kicker-border)] rounded-full px-[0.58rem] py-[0.27rem] bg-[var(--kicker-bg)] transition-[border-color,background] duration-300" data-i18n="services.card1.kicker">Build</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="services.card1.title">Desarrollo de productos</h3>
              <p class="mt-[0.58rem] mb-[0.58rem] text-[var(--muted)]" data-i18n="services.card1.desc">Landing pages, plataformas web y APIs enfocadas en performance y conversión.</p>
              <ul class="m-0 pl-[1.05rem] leading-[1.38] text-[var(--list-color)]">
                <li data-i18n="services.card1.li1">Arquitectura frontend y backend</li>
                <li data-i18n="services.card1.li2">Integraciones con CRM y pagos</li>
                <li data-i18n="services.card1.li3">Medición de eventos y embudos</li>
              </ul>
            </article>
            <article class="service-card col-span-4 max-[980px]:col-span-6 max-[760px]:col-span-12 border border-[var(--card-border)] rounded-[18px] p-4 bg-[var(--paper)] shadow-[0_10px_24px_rgba(25,35,46,0.07)] hover:-translate-y-[5px] hover:shadow-[0_18px_34px_rgba(25,35,46,0.14)] transition-[transform,box-shadow,border-color,background] duration-[220ms]">
              <p class="m-0 mb-2 inline-flex text-[0.72rem] uppercase tracking-[0.12em] text-[var(--brand)] border border-[var(--kicker-border)] rounded-full px-[0.58rem] py-[0.27rem] bg-[var(--kicker-bg)] transition-[border-color,background] duration-300" data-i18n="services.card2.kicker">Delivery</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="services.card2.title">Gestión de proyectos</h3>
              <p class="mt-[0.58rem] mb-[0.58rem] text-[var(--muted)]" data-i18n="services.card2.desc">Planificación clara, seguimiento visible y entregables con impacto en negocio.</p>
              <ul class="m-0 pl-[1.05rem] leading-[1.38] text-[var(--list-color)]">
                <li data-i18n="services.card2.li1">Roadmap por fases</li>
                <li data-i18n="services.card2.li2">Ritmo semanal con reportes</li>
                <li data-i18n="services.card2.li3">Control de riesgo y alcance</li>
              </ul>
            </article>
            <article class="service-card col-span-4 max-[980px]:col-span-6 max-[760px]:col-span-12 border border-[var(--card-border)] rounded-[18px] p-4 bg-[var(--paper)] shadow-[0_10px_24px_rgba(25,35,46,0.07)] hover:-translate-y-[5px] hover:shadow-[0_18px_34px_rgba(25,35,46,0.14)] transition-[transform,box-shadow,border-color,background] duration-[220ms]">
              <p class="m-0 mb-2 inline-flex text-[0.72rem] uppercase tracking-[0.12em] text-[var(--brand)] border border-[var(--kicker-border)] rounded-full px-[0.58rem] py-[0.27rem] bg-[var(--kicker-bg)] transition-[border-color,background] duration-300" data-i18n="services.card3.kicker">Growth</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="services.card3.title">Marketing y automatización</h3>
              <p class="mt-[0.58rem] mb-[0.58rem] text-[var(--muted)]" data-i18n="services.card3.desc">Captación de leads y mejora de conversión con ejecución orientada a datos.</p>
              <ul class="m-0 pl-[1.05rem] leading-[1.38] text-[var(--list-color)]">
                <li data-i18n="services.card3.li1">Campañas y funnels</li>
                <li data-i18n="services.card3.li2">Email journeys</li>
                <li data-i18n="services.card3.li3">Analítica accionable</li>
              </ul>
            </article>
            <article class="service-card col-span-4 max-[980px]:col-span-6 max-[760px]:col-span-12 border border-[var(--card-border)] rounded-[18px] p-4 bg-[var(--paper)] shadow-[0_10px_24px_rgba(25,35,46,0.07)] hover:-translate-y-[5px] hover:shadow-[0_18px_34px_rgba(25,35,46,0.14)] transition-[transform,box-shadow,border-color,background] duration-[220ms]">
              <p class="m-0 mb-2 inline-flex text-[0.72rem] uppercase tracking-[0.12em] text-[var(--brand)] border border-[var(--kicker-border)] rounded-full px-[0.58rem] py-[0.27rem] bg-[var(--kicker-bg)] transition-[border-color,background] duration-300" data-i18n="services.card4.kicker">Cloud</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="services.card4.title">Cloud y DevOps</h3>
              <p class="mt-[0.58rem] mb-[0.58rem] text-[var(--muted)]" data-i18n="services.card4.desc">Infraestructura moderna, despliegues continuos y entornos seguros.</p>
              <ul class="m-0 pl-[1.05rem] leading-[1.38] text-[var(--list-color)]">
                <li data-i18n="services.card4.li1">Entornos dev, staging y prod</li>
                <li data-i18n="services.card4.li2">CI/CD y monitoreo</li>
                <li data-i18n="services.card4.li3">Costos cloud optimizados</li>
              </ul>
            </article>
            <article class="service-card col-span-4 max-[980px]:col-span-6 max-[760px]:col-span-12 border border-[var(--card-border)] rounded-[18px] p-4 bg-[var(--paper)] shadow-[0_10px_24px_rgba(25,35,46,0.07)] hover:-translate-y-[5px] hover:shadow-[0_18px_34px_rgba(25,35,46,0.14)] transition-[transform,box-shadow,border-color,background] duration-[220ms]">
              <p class="m-0 mb-2 inline-flex text-[0.72rem] uppercase tracking-[0.12em] text-[var(--brand)] border border-[var(--kicker-border)] rounded-full px-[0.58rem] py-[0.27rem] bg-[var(--kicker-bg)] transition-[border-color,background] duration-300" data-i18n="services.card5.kicker">Quality</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="services.card5.title">QA y calidad de producto</h3>
              <p class="mt-[0.58rem] mb-[0.58rem] text-[var(--muted)]" data-i18n="services.card5.desc">Pruebas funcionales y técnicas para reducir bugs en producción.</p>
              <ul class="m-0 pl-[1.05rem] leading-[1.38] text-[var(--list-color)]">
                <li data-i18n="services.card5.li1">Estrategia QA por riesgo</li>
                <li data-i18n="services.card5.li2">Automatización de pruebas clave</li>
                <li data-i18n="services.card5.li3">Checklists de release</li>
              </ul>
            </article>
          </div>
        </div>
      </section>

      <!-- ── Proceso ─────────────────────────────────────── -->
      <section id="proceso" class="flex items-center min-h-[100svh] max-[980px]:min-h-0 py-20 max-[980px]:py-[4.1rem] bg-[var(--tone-b)] transition-[background] duration-[400ms] scroll-mt-[74px] reveal">
        <div class="wrapper py-4">
          <div class="section-heading max-w-[760px]">
            <p class="m-0 mb-3 text-[var(--brand)] text-[0.73rem] uppercase tracking-[0.15em] font-bold" data-i18n="process.eyebrow">Método de trabajo</p>
            <h2 class="m-0 text-[clamp(1.7rem,3.8vw,2.65rem)] leading-[1.09] text-[var(--ink)]" data-i18n="process.headline">Un proceso simple, medible y orientado a resultados</h2>
            <p class="mt-[0.7rem] mb-0 text-[var(--muted)] max-w-[56ch]" data-i18n="process.lead">
              Transparencia total, decisiones rápidas y entregas iterativas para sostener crecimiento.
            </p>
          </div>
          <div class="mt-5 grid grid-cols-4 max-[980px]:grid-cols-2 max-[760px]:grid-cols-1 gap-3">
            <article class="border border-[var(--card-border)] rounded-[18px] bg-[var(--paper)] p-4 transition-[border-color,background] duration-300">
              <span class="text-[var(--accent)] font-bold text-[0.84rem]">01</span>
              <h3 class="mt-[0.42rem] mb-[0.42rem] m-0 text-[var(--ink)]" data-i18n="process.step1.title">Discovery</h3>
              <p class="m-0 text-[var(--muted)]" data-i18n="process.step1.desc">Entendemos objetivos, restricciones y oportunidades para definir una estrategia sólida.</p>
            </article>
            <article class="border border-[var(--card-border)] rounded-[18px] bg-[var(--paper)] p-4 transition-[border-color,background] duration-300">
              <span class="text-[var(--accent)] font-bold text-[0.84rem]">02</span>
              <h3 class="mt-[0.42rem] mb-[0.42rem] m-0 text-[var(--ink)]" data-i18n="process.step2.title">Plan de ejecución</h3>
              <p class="m-0 text-[var(--muted)]" data-i18n="process.step2.desc">Definimos alcance por fases, stack técnico y prioridades de negocio.</p>
            </article>
            <article class="border border-[var(--card-border)] rounded-[18px] bg-[var(--paper)] p-4 transition-[border-color,background] duration-300">
              <span class="text-[var(--accent)] font-bold text-[0.84rem]">03</span>
              <h3 class="mt-[0.42rem] mb-[0.42rem] m-0 text-[var(--ink)]" data-i18n="process.step3.title">Implementación</h3>
              <p class="m-0 text-[var(--muted)]" data-i18n="process.step3.desc">Construimos con entregas iterativas, feedback continuo y foco en calidad.</p>
            </article>
            <article class="border border-[var(--card-border)] rounded-[18px] bg-[var(--paper)] p-4 transition-[border-color,background] duration-300">
              <span class="text-[var(--accent)] font-bold text-[0.84rem]">04</span>
              <h3 class="mt-[0.42rem] mb-[0.42rem] m-0 text-[var(--ink)]" data-i18n="process.step4.title">Escalado</h3>
              <p class="m-0 text-[var(--muted)]" data-i18n="process.step4.desc">Optimizamos conversión, rendimiento y operaciones para sostener crecimiento.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- ── Resultados ───────────────────────────────────── -->
      <section id="resultados" class="flex items-center min-h-[100svh] max-[980px]:min-h-0 py-20 max-[980px]:py-[4.1rem] bg-[var(--tone-c)] transition-[background] duration-[400ms] scroll-mt-[74px] reveal">
        <div class="wrapper py-4">
          <div class="results-grid grid grid-cols-3 max-[980px]:grid-cols-1 gap-[0.85rem]">
            <article class="border border-[var(--results-border)] rounded-[18px] bg-[var(--results-bg)] shadow-[0_10px_24px_rgba(16,47,64,0.1)] p-4 transition-[border-color,background] duration-300">
              <p class="m-0 mb-[0.35rem] text-[var(--brand)] uppercase tracking-[0.11em] text-[0.72rem]" data-i18n="results.article1.label">Operación</p>
              <p class="m-0 mb-[0.3rem] text-[clamp(1.7rem,3.2vw,2.4rem)] text-[var(--brand-strong)] font-bold" data-i18n="results.article1.value">+120</p>
              <h3 class="m-0 text-[var(--ink)]" data-i18n="results.article1.title">Sprints ejecutados</h3>
              <span class="block mt-[0.42rem] text-[var(--muted)]" data-i18n="results.article1.desc">Con equipos de producto y marketing en distintas industrias.</span>
            </article>
            <article class="border border-[var(--results-border)] rounded-[18px] bg-[var(--results-bg)] shadow-[0_10px_24px_rgba(16,47,64,0.1)] p-4 transition-[border-color,background] duration-300">
              <p class="m-0 mb-[0.35rem] text-[var(--brand)] uppercase tracking-[0.11em] text-[0.72rem]" data-i18n="results.article2.label">Eficiencia</p>
              <p class="m-0 mb-[0.3rem] text-[clamp(1.7rem,3.2vw,2.4rem)] text-[var(--brand-strong)] font-bold" data-i18n="results.article2.value">98%</p>
